# ─── Backend LLM Configuration ────────────────────────────────────────────────
# Primary: Ollama (local). Fallback: Groq (cloud, requires API key below)
#
# Ollama model options (run: ollama pull <model>):
#   phi3:mini         — Sanitizer (fast, small)
#   mistral:7b        — Governor (good reasoning)
#   llama3.1:8b       — Main Agent (general purpose)
#   llama3.2:latest   — Alternative general model

SANITIZER_MODEL=llama3.2:latest
GOVERNOR_MODEL=llama3.2:latest
MAIN_AGENT_MODEL=llama3.2:latest

# ─── Groq Fallback ────────────────────────────────────────────────────────────
# Set this to enable Groq as automatic fallback when Ollama is unavailable.
# Get a free key at: https://console.groq.com
# When set, Groq models are used:
#   Sanitizer → llama-3.1-8b-instant
#   Governor  → mixtral-8x7b-32768
#   Main Agent → llama-3.1-70b-versatile
GROQ_API_KEY=

# ─── Server Configuration ─────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
DB_PATH=./database/aegis_audit.db
MAX_REFUND_AMOUNT=200
